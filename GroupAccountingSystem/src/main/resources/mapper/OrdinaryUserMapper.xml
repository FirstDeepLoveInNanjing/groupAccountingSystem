<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.groupaccountingsystem.mapper.OrdinaryUserMapper">

    <!-- 登录查询 -->
    <select id="selectByAccountAndPassword" resultType="ordinaryUser">
        SELECT *
        FROM user
        WHERE (phoneNumber = #{account} OR userMailbox= #{account})
          AND userPassword = #{userPassword}
          AND userType = '普通用户'
    </select>

    <!-- 根据用户名查询 -->
    <select id="selectByUserName" resultType="ordinaryUser">
        SELECT *
        FROM user
        WHERE userName = #{userName}
    </select>

    <!-- 根据手机号查询 -->
    <select id="selectByPhoneNumber" resultType="ordinaryUser">
        SELECT *
        FROM user
        WHERE phoneNumber = #{phoneNumber}
    </select>

    <!-- 根据邮箱查询 -->
    <select id="selectByUserMailbox" resultType="ordinaryUser">
        SELECT *
        FROM user
        WHERE userMailbox = #{userMailbox}
    </select>

    <!-- 插入新用户（userID 假设是自增主键，由数据库生成） -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="userID">
        INSERT INTO user (userID, userPassword, userType, phoneNumber, userMailbox, userName, registerTime)
        VALUES (#{userID}, #{userPassword}, #{userType}, #{phoneNumber}, #{userMailbox}, #{userName}, #{registerTime})
    </insert>

</mapper>
