<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.groupaccountingsystem.mapper.AdministratorMapper">

    <select id="selectByAccountAndPassword" resultType="administrator">
        SELECT *
        FROM user
        WHERE userID = #{userID}
            AND userPassword = #{userPassword}
            AND userType = "管理员"
    </select>

</mapper>